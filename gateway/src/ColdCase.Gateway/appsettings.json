{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://0.0.0.0:5000",
  "UserService": {
    "BaseUrl": "http://localhost:8080"
  },
  "AiService": {
    "BaseUrl": "http://localhost:8000"
  },
  "Jwt": {
    "Key": "ColdCaseAI_DevSigningKey_2024_SuperSecret!",
    "Issuer": "coldcase-ai",
    "Audience": "coldcase-api",
    "ExpiryHours": 24
  },
  "ReverseProxy": {
    "Routes": {
      "user-service-route": {
        "ClusterId": "user-service",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/users/{**catch-all}" }
        ]
      },
      "ai-service-route": {
        "ClusterId": "ai-service",
        "Match": {
          "Path": "/api/ai/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/ai/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "user-service": {
        "Destinations": {
          "default": {
            "Address": "http://localhost:8080"
          }
        }
      },
      "ai-service": {
        "Destinations": {
          "default": {
            "Address": "http://localhost:8000"
          }
        }
      }
    }
  }
}
